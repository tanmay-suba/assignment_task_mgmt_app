# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_DB=taskapp
# Bind Postgres only to localhost on the VPS (not 0.0.0.0)
POSTGRES_PORT=127.0.0.1:5432

# API
API_PORT=127.0.0.1:5050
CORS_ALLOWED_ORIGINS=https://tasks.tanmaysuba.com

# Web (only used when running the local-fullstack docker demo)
WEB_PORT=8080
